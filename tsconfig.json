{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "Bundler",
    "paths": {
      "@domain/*": ["./src/domain/*"],
      "@application/*": ["./src/application/*"],
      "@infrastructure/*": ["./src/infrastructure/*"],
      "@types/*": ["./src/types/*"]
    }
  }
}
