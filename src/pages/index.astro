---
import "../styles/global.css";
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <title>iCliiniq Shopping Cart</title>
</head>

<body>

<div class="min-h-screen">

  <header class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-6 py-5">
      <h1 class="text-3xl font-bold">
        Shopping Cart Application
      </h1>

      <p class="text-slate-500 mt-1">
        Astro + TypeScript + DDD + Docker
      </p>
    </div>
  </header>

  <main
    class="
      max-w-7xl
      mx-auto
      px-6
      py-8
      grid
      lg:grid-cols-3
      gap-8
    "
  >

    <!-- PRODUCTS -->

    <section class="lg:col-span-2">

      <div
        class="
          flex
          justify-between
          items-center
          mb-6
        "
      >
        <h2 class="text-2xl font-semibold">
          Products
        </h2>
      </div>

      <div
        id="products"
        class="
          grid
          md:grid-cols-2
          xl:grid-cols-3
          gap-6
        "
      >
      </div>

    </section>

    <!-- CART -->

    <aside>

      <div
        class="
          cart-card
          sticky
          top-6
          p-6
        "
      >

        <h2
          class="
            text-2xl
            font-semibold
            mb-6
          "
        >
          Shopping Cart
        </h2>

        <div id="cart"></div>

        <div
          class="
            mt-6
            pt-4
            border-t
            flex
            justify-between
            font-bold
            text-lg
          "
        >
          <span>Total</span>

          <span id="total">
            ₹0
          </span>
        </div>

      </div>

    </aside>

  </main>

</div>

<script>
  let products = [];
  let cart = null;

  async function loadProducts() {
    const response =
      await fetch("/api/products");

    products =
      await response.json();

    renderProducts();
  }

  async function loadCart() {
    const response =
      await fetch("/api/cart");

    cart =
      await response.json();

    renderCart();
  }

  async function addToCart(productId) {
    await fetch("/api/cart/items", {
      method: "POST",
      headers: {
        "Content-Type":
          "application/json"
      },
      body: JSON.stringify({
        productId,
        quantity: 1
      })
    });

    await loadCart();
  }

  async function increase(productId) {
    const item =
      cart.items.find(
        i => i.productId === productId
      );

    await fetch(
      `/api/cart/items/${productId}`,
      {
        method: "PATCH",
        headers: {
          "Content-Type":
            "application/json"
        },
        body: JSON.stringify({
          quantity:
            item.quantity + 1
        })
      }
    );

    await loadCart();
  }

  async function decrease(productId) {
    const item =
      cart.items.find(
        i => i.productId === productId
      );

    if (item.quantity === 1) {
      await removeItem(productId);
      return;
    }

    await fetch(
      `/api/cart/items/${productId}`,
      {
        method: "PATCH",
        headers: {
          "Content-Type":
            "application/json"
        },
        body: JSON.stringify({
          quantity:
            item.quantity - 1
        })
      }
    );

    await loadCart();
  }

  async function removeItem(productId) {
    await fetch(
      `/api/cart/items/${productId}`,
      {
        method: "DELETE"
      }
    );

    await loadCart();
  }

  function renderProducts() {
    const container =
      document.getElementById(
        "products"
      );

    container.innerHTML =
      products.map(product => `
        <div class="product-card p-5">

          <div class="mb-4">
            <h3 class="font-semibold text-lg">
              ${product.name}
            </h3>

            <p class="text-2xl font-bold mt-2">
              ₹${product.price}
            </p>
          </div>

          <button
            onclick="addToCart('${product.id}')"
            class="
              w-full
              bg-blue-600
              hover:bg-blue-700
              text-white
              rounded-lg
              py-3
              transition
            "
          >
            Add To Cart
          </button>

        </div>
      `).join("");
  }

  function renderCart() {
    const container =
      document.getElementById("cart");

    let total = 0;

    if (!cart.items.length) {
      container.innerHTML = `
        <div class="text-center py-8 text-slate-500">
          Cart is empty
        </div>
      `;

      document.getElementById(
        "total"
      ).innerText = "₹0";

      return;
    }

    container.innerHTML =
      cart.items.map(item => {
        const product =
          products.find(
            p => p.id === item.productId
          );

        const amount =
          product.price * item.quantity;

        total += amount;

        return `
          <div
            class="
              border-b
              py-4
            "
          >

            <div class="font-medium">
              ${product.name}
            </div>

            <div
              class="
                text-sm
                text-slate-500
                mb-3
              "
            >
              ₹${product.price}
            </div>

            <div
              class="
                flex
                justify-between
                items-center
              "
            >

              <div
                class="
                  flex
                  gap-2
                  items-center
                "
              >
                <button
                  onclick="decrease('${item.productId}')"
                  class="px-3 py-1 border rounded"
                >
                  -
                </button>

                <span>
                  ${item.quantity}
                </span>

                <button
                  onclick="increase('${item.productId}')"
                  class="px-3 py-1 border rounded"
                >
                  +
                </button>
              </div>

              <button
                onclick="removeItem('${item.productId}')"
                class="
                  text-red-600
                  text-sm
                "
              >
                Remove
              </button>

            </div>

          </div>
        `;
      }).join("");

    document.getElementById(
      "total"
    ).innerText = `₹${total}`;
  }

  window.addToCart = addToCart;
  window.increase = increase;
  window.decrease = decrease;
  window.removeItem = removeItem;

  Promise.all([
    loadProducts(),
    loadCart()
  ]);
</script>

</body>
</html>